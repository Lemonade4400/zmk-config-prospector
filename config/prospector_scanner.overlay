/*
 * User overlay: Test inverted backlight polarity
 * If the backlight is active-LOW, inverting the PWM should turn it on.
 */

/* Override pwmleds to use inverted polarity */
/ {
    pwmleds {
        backlight: backlight {
            pwms = <&pwm0 0 PWM_USEC(1000) PWM_POLARITY_INVERTED>;
        };
    };
};
