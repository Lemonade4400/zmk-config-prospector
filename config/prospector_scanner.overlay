/*
 * GPIO Backlight Test Overlay
 *
 * Disables the PWM backlight from the module so our GPIO test takes over.
 * The gpio-backlight-test module drives P1.11 as a raw GPIO output
 * and toggles it every 2 seconds to determine the correct polarity.
 */

/* Disable PWM backlight so backlight_init.c does nothing */
/ {
    pwmleds {
        status = "disabled";
    };
};

/* Disable PWM0 peripheral (not needed for GPIO test) */
&pwm0 {
    status = "disabled";
};
